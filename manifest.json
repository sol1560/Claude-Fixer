{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "0.3.0",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "unlimitedStorage",
    "tabs"
  ],
  "host_permissions": [
    "*://claude.ai/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://claude.ai/*"],
      "js": [
        "src/storage.js",
        "src/font-css.js",
        "src/font-probe.js",
        "src/i18n-zh.js",
        "src/in-page-ui.js",
        "src/content.js"
      ],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/injected.js"],
      "matches": ["*://claude.ai/*"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "__MSG_extName__",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
