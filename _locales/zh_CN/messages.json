  "statusOn":  { "message": "开" },
  "statusOff": { "message": "关" },
  "statusFontLabel":  { "message": "字体" },
  "statusModelLabel": { "message": "模型修复" },
  "statusFormat": {
    "message": "$FONT_LABEL$：$FONT_STATE$（$MODE$） · $MODEL_LABEL$：$MODEL_STATE$",
    "placeholders": {
      "font_label":  { "content": "$1" },
      "font_state":  { "content": "$2" },
      "mode":        { "content": "$3" },
      "model_label": { "content": "$4" },
      "model_state": { "content": "$5" }
    }
  },

  "modeLabelAnthropic": { "message": "Anthropic Serif" },
  "modeLabelLocal": {
    "message": "本地 $COUNT$/$TOTAL$",
    "placeholders": {
      "count": { "content": "$1" },
      "total": { "content": "$2" }
    }
  },
  "modeLabelOnline": { "message": "在线" },

  "extracting": { "message": "正在解压…" },
  "imported": {
    "message": "已导入 $COUNT$ 个字体。",
    "placeholders": {
      "count": { "content": "$1", "example": "8" }
    }
  },
  "importFailed": {
    "message": "导入失败：$REASON$",
    "placeholders": {
      "reason": { "content": "$1" }
    }
  },
  "fontReadFailed": {
    "message": "读取字体文件失败：$REASON$",
    "placeholders": {
      "reason": { "content": "$1" }
    }
  }
